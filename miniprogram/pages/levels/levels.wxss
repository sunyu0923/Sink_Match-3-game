.levels-page {
  width: 100vw;
  height: 100vh;
  background: linear-gradient(180deg, #5A3E1B 0%, #8B6914 40%, #A07828 100%);
  display: flex;
  flex-direction: column;
}

.levels-header {
  text-align: center;
  padding: 40rpx 0 20rpx;
  padding-top: calc(env(safe-area-inset-top) + 40rpx);
}

.levels-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFD700;
}

.levels-grid-wrap {
  flex: 1;
  padding: 20rpx 30rpx;
}

.levels-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: flex-start;
}

.level-card {
  width: calc(25% - 15rpx);
  aspect-ratio: 1;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.level-unlocked {
  background: linear-gradient(135deg, #FFF8E7, #F5E6C8);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.level-locked {
  background: rgba(0,0,0,0.3);
}

.level-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #5B3A0A;
}

.level-locked .level-num {
  color: #888;
}

.level-stars {
  display: flex;
  gap: 2rpx;
  margin-top: 4rpx;
}

.lstar {
  font-size: 20rpx;
  color: #ccc;
}

.lstar-on {
  color: #FFD700;
}

.lock-icon {
  font-size: 24rpx;
  margin-top: 4rpx;
}
