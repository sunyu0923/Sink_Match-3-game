<view class="home-page">
  <view class="home-bg">
    <!-- 标题 -->
    <view class="title-area">
      <text class="title-main">水槽消消乐</text>
      <text class="title-sub">厨具大挑战</text>
    </view>

    <!-- 装饰：水槽图标 -->
    <view class="deco-sink">
      <text class="deco-emoji">🍳</text>
    </view>

    <!-- 统计 -->
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-icon">⭐</text>
        <text class="stat-value">{{totalStars}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-icon">🏆</text>
        <text class="stat-value">第{{currentLevel}}关</text>
      </view>
    </view>

    <!-- 按钮 -->
    <view class="btn-area">
      <button class="btn-start" bindtap="onStartGame">开始游戏</button>
      <button class="btn-levels" bindtap="onSelectLevel">选择关卡</button>
    </view>

    <text class="version-text">v1.0.0</text>
  </view>
</view>
