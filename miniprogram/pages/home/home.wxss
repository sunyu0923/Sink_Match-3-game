.home-page {
  width: 100vw;
  height: 100vh;
}

.home-bg {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #5A3E1B 0%, #8B6914 40%, #A07828 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.title-area {
  text-align: center;
  margin-bottom: 40rpx;
}

.title-main {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  color: #FFD700;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.4);
}

.title-sub {
  display: block;
  font-size: 36rpx;
  color: #FFF8E7;
  margin-top: 8rpx;
}

.deco-sink {
  margin: 40rpx 0;
}

.deco-emoji {
  font-size: 160rpx;
}

.stats-row {
  display: flex;
  gap: 60rpx;
  margin-bottom: 60rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(0,0,0,0.25);
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
}

.stat-icon {
  font-size: 36rpx;
}

.stat-value {
  font-size: 30rpx;
  color: #FFD700;
  font-weight: bold;
}

.btn-area {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 500rpx;
}

.btn-start {
  background: linear-gradient(135deg, #4CAF50, #388E3C) !important;
  color: #fff !important;
  font-size: 38rpx !important;
  font-weight: bold !important;
  padding: 28rpx 0 !important;
  border-radius: 20rpx !important;
  border: none !important;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.4);
}

.btn-levels {
  background: rgba(255,255,255,0.15) !important;
  color: #FFF8E7 !important;
  font-size: 32rpx !important;
  padding: 24rpx 0 !important;
  border-radius: 20rpx !important;
  border: 2rpx solid rgba(255,255,255,0.3) !important;
}

.version-text {
  position: absolute;
  bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
}
