<view class="slot-bar">
  <!-- 盘子区（上排） -->
  <view class="plates-row">
    <view
      class="plate {{plateUnlocked[index] ? 'plate-unlocked' : 'plate-locked'}}"
      wx:for="{{plates}}"
      wx:key="index"
      data-index="{{index}}"
      bindtap="onPlateTap"
    >
      <block wx:if="{{!plateUnlocked[index]}}">
        <text class="lock-icon">🔒</text>
        <text class="lock-text">解锁</text>
      </block>
      <block wx:elif="{{item}}">
        <text class="plate-emoji">{{emojiMap[item.type] || '?'}}</text>
      </block>
    </view>
  </view>

  <!-- 队列区（下排） -->
  <view class="queue-row">
    <view
      class="queue-slot {{item ? 'slot-filled' : 'slot-empty'}}"
      wx:for="{{queueSlots}}"
      wx:key="index"
    >
      <text wx:if="{{item}}" class="slot-emoji">{{emojiMap[item.type] || '?'}}</text>
    </view>
  </view>
</view>
