.slot-bar {
  padding: 12rpx 20rpx;
  background: rgba(0,0,0,0.2);
}

/* --- 盘子区 --- */
.plates-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.plate {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.plate-unlocked {
  background: radial-gradient(circle, #FFF8E7 40%, #E8D8B8 100%);
  border: 4rpx solid #C8B898;
  box-shadow: inset 0 2rpx 6rpx rgba(0,0,0,0.1);
}

.plate-locked {
  background: #555;
  border: 4rpx solid #444;
}

.lock-icon {
  font-size: 28rpx;
}

.lock-text {
  font-size: 18rpx;
  color: #ccc;
  margin-top: 2rpx;
}

.plate-emoji {
  font-size: 44rpx;
}

/* --- 队列区 --- */
.queue-row {
  display: flex;
  justify-content: center;
  gap: 8rpx;
}

.queue-slot {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.slot-empty {
  background: rgba(255,255,255,0.2);
  border: 2rpx dashed rgba(255,255,255,0.3);
}

.slot-filled {
  background: #FFF8E7;
  border: 2rpx solid #D4C4A0;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
}

.slot-emoji {
  font-size: 36rpx;
}
