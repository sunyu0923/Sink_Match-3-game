.tool-bar {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 40rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 16rpx);
  background: rgba(0,0,0,0.25);
}

.tool-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.tool-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #5A5A5A, #333);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border: 3rpx solid #666;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.4);
}

.tool-icon {
  font-size: 40rpx;
}

.tool-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: #E53935;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.tool-badge-ad {
  background: #4CAF50;
}

.badge-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
}

.tool-name {
  font-size: 22rpx;
  color: #FFF8E7;
}
