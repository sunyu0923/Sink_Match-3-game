<view class="hud">
  <!-- 左侧：暂停 + 关卡号 -->
  <view class="hud-left">
    <view class="pause-btn" bindtap="onPauseTap">
      <text class="pause-icon">⏸</text>
    </view>
    <view class="level-badge">
      <text class="level-text">第{{levelId}}关</text>
    </view>
  </view>

  <!-- 中间：目标 -->
  <view class="hud-goals">
    <view class="goal-item" wx:for="{{goalList}}" wx:key="type">
      <view class="goal-icon-wrap">
        <text class="goal-emoji">{{type === 'chopstick' ? '🥢' : type === 'spoon' ? '🥄' : type === 'fork' ? '🍴' : type === 'spatula' ? '🔪' : type === 'whisk' ? '🔄' : type === 'ladle' ? '🥣' : type === 'board' ? '🪵' : '📏'}}</text>
      </view>
      <text class="goal-count">x{{item.count}}</text>
    </view>
  </view>

  <!-- 右侧：金币 -->
  <view class="hud-right">
    <text class="coin-icon">⭐</text>
    <text class="coin-count">0</text>
  </view>
</view>
