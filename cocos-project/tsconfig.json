{
  "compilerOptions": {
    "strict": false,
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "outDir": "./temp/programming/pipe-script",
    "rootDir": "./assets"
  },
  "include": ["assets/**/*.ts"],
  "exclude": ["node_modules", "library", "local", "temp", "build", "settings", "tests"]
}
